<form class="lawful-manager-form">
    <p class="lawful-manager-hint">
        Configure per-user overrides below. <strong>"Default"</strong> follows the Global setting.
        <strong>"Lock"</strong> forces the lock regardless of role.
        <strong>"Unlock"</strong> exempts the user from that lock.
        <strong>"Request"</strong> sends a GM approval chat card instead of blocking outright.
        Indented rows under <em>Inventory</em> are subcategories that override it.
    </p>

    <div class="lawful-manager-body">
        <table class="lawful-manager-table">
            <thead>
                <tr>
                    <th class="user-col">User</th>
                    {{#each columns}}
                    <th class="category-col {{#if this.isSub}}sub-col{{/if}}" title="Global: {{this.globalLabel}}">
                        {{#if this.isSub}}<span class="sub-indent">↳</span>{{/if}}{{this.name}}
                    </th>
                    {{/each}}
                    <th class="action-col"></th>
                </tr>
            </thead>
            <tbody>
                {{#each users}}
                <tr data-user-id="{{this.id}}">
                    <td class="user-col">
                        <strong>{{this.name}}</strong>
                        <span class="user-role {{this.roleClass}}">{{this.role}}</span>
                    </td>
                    {{#each this.cells}}
                    <td class="category-col {{#if this.isSub}}sub-col{{/if}}">
                        <select name="{{this.name}}">
                            {{#each this.choices}}
                            <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                            {{/each}}
                        </select>
                    </td>
                    {{/each}}
                    <td class="action-col">
                        <button type="button" data-action="resetUser" data-user-id="{{this.id}}" title="Reset all to default">
                            <i class="fas fa-undo"></i>
                        </button>
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>

    <footer class="lawful-manager-footer">
        <button type="button" data-action="save" class="save-btn">
            <i class="fas fa-save"></i> Save Laws
        </button>
    </footer>
</form>
